module top_module(
    input clk,
    input areset,    // 非同步復位至 OFF
    input j,
    input k,
    output out); 

    // 定義狀態編碼
    parameter OFF=0, ON=1; 
    reg state, next_state;

    // 1. 組合邏輯：決定下一個狀態 (State Transition Logic)
    always @(*) begin
        case (state)
            OFF: next_state = j ? ON : OFF;
            ON:  next_state = k ? OFF : ON;
            default: next_state = OFF;
        endcase
    end

    // 2. 時序邏輯：更新目前狀態 (State Register with Asynchronous Reset)
    always @(posedge clk or posedge areset) begin
        if (areset) begin
            state <= OFF;
        end else begin
            state <= next_state;
        end
    end

    // 3. 輸出邏輯 (Output Logic)
    assign out = (state == ON);

endmodule

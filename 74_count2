module top_module (
    input clk,
    input reset,        // 同步高電位重置
    output reg [3:0] q
);

    always @(posedge clk) begin
        if (reset) begin
            // 情況 1: 外部重置
            q <= 4'd0;
        end else if (q == 4'd9) begin
            // 情況 2: 達到最大值 9，手動歸零實現循環
            q <= 4'd0;
        end else begin
            // 一般情況：累加
            q <= q + 1'b1;
        end
    end

endmodule

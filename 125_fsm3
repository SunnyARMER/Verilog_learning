
module top_module(
    input clk,
    input areset,    // 非同步重置 (Asynchronous reset)
    input in,
    output out
); 

    // 定義狀態編碼
    parameter A=0, B=1, C=2, D=3;
    reg [1:0] state, next_state;

    // 第一段：狀態轉移邏輯 (Next state logic) - 組合電路
    always @(*) begin
        case (state)
            A: next_state = in ? B : A;
            B: next_state = in ? B : C;
            C: next_state = in ? D : A;
            D: next_state = in ? B : C;
            default: next_state = A;
        endcase
    end

    // 第二段：狀態暫存器 (State register) - 循序電路 (含非同步重置)
    always @(posedge clk or posedge areset) begin
        if (areset) 
            state <= A;
        else 
            state <= next_state;
    end

    // 第三段：輸出邏輯 (Output logic) - Moore machine 輸出僅取決於 state
    assign out = (state == D);

endmodule







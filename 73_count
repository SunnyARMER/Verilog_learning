module top_module (
    input clk,
    input reset,      // 同步主動高電位重置
    output [3:0] q
);

    // 使用 always 區塊描述正反器邏輯
    always @(posedge clk) begin
        if (reset) begin
            // 同步重置：在時脈上升沿且 reset 為 1 時清零
            q <= 4'b0;
        end else begin
            // 否則每個時脈週期加 1
            // 4位元變數加到 15 後自動溢位回到 0
            q <= q + 1'b1;
        end
    end

endmodule

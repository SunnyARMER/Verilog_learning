module top_module(
    input clk,
    input reset,    // 同步重置
    input in,
    output out
);

    // 1. 定義狀態參數
    parameter A = 0, B = 1;
    reg present_state, next_state;

    // 2. 狀態轉移邏輯 (組合邏輯 - Next State Logic)
    always @(*) begin
        case (present_state)
            A: next_state = (in == 1'b0) ? B : A;
            B: next_state = (in == 1'b0) ? A : B;
            default: next_state = B;
        endcase
    end

    // 3. 狀態暫存器 (序向邏輯 - State Register)
    // 注意：同步重置不將 reset 放在敏感列表中
    always @(posedge clk) begin
        if (reset) begin
            present_state <= B; // 題目要求重置到 B
        end else begin
            present_state <= next_state;
        end
    end

    // 4. 輸出邏輯 (組合邏輯 - Output Logic)
    assign out = (present_state == B);

endmodule

module top_module (
    input clk,
    input areset,
    input load,
    input ena,
    input [3:0] data,
    output reg [3:0] q
);

    always @(posedge clk or posedge areset) begin
        if (areset) begin
            q <= 4'b0000;
        end
        else if (load) begin
            q <= data;
        end
        else if (ena) begin
            q <= {1'b0, q[3:1]};
            // 也可以寫 q <= q >> 1; 但要注意工具是否支援
        end
        // 沒寫 else → 自動保持原值 (latch-free)
    end

endmodule
